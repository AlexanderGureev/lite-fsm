{
  "name": "@lite-fsm/graph",
  "version": "0.1.1",
  "type": "module",
  "description": "Alpha graph compiler for lite-fsm",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./simulator": {
      "import": {
        "types": "./dist/simulator/index.d.ts",
        "default": "./dist/simulator/index.js"
      },
      "require": {
        "types": "./dist/simulator/index.d.cts",
        "default": "./dist/simulator/index.cjs"
      }
    },
    "./view-model": {
      "import": {
        "types": "./dist/view-model/index.d.ts",
        "default": "./dist/view-model/index.js"
      },
      "require": {
        "types": "./dist/view-model/index.d.cts",
        "default": "./dist/view-model/index.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ],
      "simulator": [
        "dist/simulator/index.d.ts"
      ],
      "view-model": [
        "dist/view-model/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "lite-fsm",
    "fsm",
    "finite-state-machine",
    "state-machine",
    "statechart",
    "graph",
    "visualization",
    "static-analysis",
    "state-management",
    "lightweight",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderGureev/lite-fsm.git",
    "directory": "packages/graph"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ts-morph": "^27.0.2"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.build.json && node ../../scripts/dts-to-dcts.mjs dist",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts"
  }
}
