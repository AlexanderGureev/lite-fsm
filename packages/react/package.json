{
  "name": "@lite-fsm/react",
  "version": "2.0.1",
  "type": "module",
  "description": "React bindings for lite-fsm",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "lite-fsm",
    "fsm",
    "finite-state-machine",
    "state-machine",
    "react",
    "react-hooks",
    "react-state",
    "state-management",
    "lightweight",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderGureev/lite-fsm.git",
    "directory": "packages/react"
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.build.json && node ../../scripts/dts-to-dcts.mjs dist",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@lite-fsm/core": "workspace:*",
    "use-sync-external-store": ">=1.2.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
