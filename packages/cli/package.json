{
  "name": "@lite-fsm/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Alpha CLI for lite-fsm project graph exports",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lite-fsm": "./dist/bin/lite-fsm.js"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "keywords": [
    "lite-fsm",
    "fsm",
    "finite-state-machine",
    "cli",
    "graph",
    "visualization",
    "static-analysis",
    "state-management",
    "developer-tools",
    "lightweight",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderGureev/lite-fsm.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @lite-fsm/graph build && node scripts/build-visualizer.mjs && tsup --config tsup.config.ts && tsc -p tsconfig.build.json && node ../../scripts/dts-to-dcts.mjs dist && chmod +x dist/bin/lite-fsm.js && node scripts/copy-visualizer.mjs && node scripts/check-visualizer-artifact.mjs",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts"
  },
  "dependencies": {
    "@lite-fsm/graph": "workspace:*",
    "commander": "^14.0.3",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.5.1",
    "vitest": "^4.1.4"
  }
}
