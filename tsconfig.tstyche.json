  "compilerOptions": {
    "rootDir": ".",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node", "react"],
    "paths": {
      "lite-fsm": ["./src/core.ts"],
      "lite-fsm/react": ["./src/react.ts"],
