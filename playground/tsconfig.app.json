{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "paths": {
      "lite-fsm": ["../src/core/index.ts"],
      "lite-fsm/react": ["../src/react/index.ts"],
      "lite-fsm/middleware": ["../src/middleware.ts"],
      "lite-fsm/middleware/devTools": ["../src/middleware/devTools.ts"],
      "lite-fsm/middleware/immer": ["../src/middleware/immer.ts"],
      "~/*": ["../src/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
