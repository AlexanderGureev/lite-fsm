{
  "name": "lite-fsm",
  "version": "2.0.0",
  "type": "module",
  "description": "lightweight finite state machine library",
  "author": "Alexander Gureev <g.alex00@bk.ru> (https://github.com/AlexanderGureev)",
  "license": "MIT",
  "main": "./dist/core.cjs",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./middleware": {
      "import": {
        "types": "./dist/middleware.d.ts",
        "default": "./dist/middleware.js"
      },
      "require": {
        "types": "./dist/middleware.d.cts",
        "default": "./dist/middleware.cjs"
      }
    },
    "./middleware/devTools": {
      "import": {
        "types": "./dist/middleware/devTools.d.ts",
        "default": "./dist/middleware/devTools.js"
      },
      "require": {
        "types": "./dist/middleware/devTools.d.cts",
        "default": "./dist/middleware/devTools.cjs"
      }
    },
    "./middleware/immer": {
      "import": {
        "types": "./dist/middleware/immer.d.ts",
        "default": "./dist/middleware/immer.js"
      },
      "require": {
        "types": "./dist/middleware/immer.d.cts",
        "default": "./dist/middleware/immer.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/core.d.ts"
      ],
      "react": [
        "dist/react.d.ts"
      ],
      "middleware": [
        "dist/middleware.d.ts"
      ],
      "middleware/devTools": [
        "dist/middleware/devTools.d.ts"
      ],
      "middleware/immer": [
        "dist/middleware/immer.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "redux",
    "fsm",
    "finite-state machine"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderGureev/lite-fsm.git"
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.build.json && node scripts/dts-to-dcts.mjs",
    "playground:sync": "npm --prefix playground run sync:lite-fsm",
    "playground:dev": "npm --prefix playground run dev",
    "playground:build": "npm --prefix playground run build",
    "lint": "eslint .",
    "lint:all": "npm run lint && npm run check-types",
    "prepare": "husky",
    "prepack": "npm run build && clean-package",
    "postpack": "clean-package restore && npm run test:release",
    "prepublishOnly": "npm run check-types && npm run lint && npm run test:coverage",
    "docs:dev": "cd docs && next dev",
    "docs:build": "cd docs && next build",
    "docs:start": "cd docs && next start",
    "pages:build": "node scripts/build-pages.mjs",
    "pages:build:fast": "node scripts/build-pages.mjs --skip-install",
    "pages:preview": "node scripts/preview-pages.mjs",
    "test": "vitest run",
    "bench": "vitest bench tests/bench",
    "test:types": "tstyche",
    "test:types:dist": "tstyche --config tstyche.dist.json",
    "test:types:all": "npm run test:types && npm run build && npm run test:types:dist",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:release": "publint --strict && node tests/smoke/esm.mjs && node tests/smoke/cjs.cjs && tsc --noEmit -p tests/smoke/tsconfig.json",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && npm run test:types && npm run build && npm run playground:sync && npm --prefix playground run check-types",
    "verify:release": "npm run check-types && npm run lint && npm run test:coverage && npm run build && npm run test:types:dist && npm pack --dry-run",
    "release": "npm publish"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "devDependencies"
    ]
  },
  "peerDependencies": {
    "immer": ">=9.x",
    "react": ">=18.0.0",
    "use-sync-external-store": ">=1.2.0"
  },
  "peerDependenciesMeta": {
    "immer": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "use-sync-external-store": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "agent-browser": "^0.26.0",
    "clean-package": "2.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "immer": "^11.1.4",
    "jsdom": "^29.0.2",
    "next": "^16.2.4",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "react": "^16.8.0 || ^17.0.2 || ^18.2.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.2 || ^18.2.0 || ^19.0.0",
    "shadcn": "^4.6.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tstyche": "^7.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "use-sync-external-store": "^1.6.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
