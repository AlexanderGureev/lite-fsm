{
  "name": "lite-fsm-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Monorepo for lite-fsm packages, docs, and playground",
  "author": "Alexander Gureev <g.alex00@bk.ru> (https://github.com/AlexanderGureev)",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "check-types": "turbo run check-types --filter='./packages/*' && tsc --noEmit -p tsconfig.test.json && pnpm run test:types",
    "check-types:apps": "pnpm run build:packages && pnpm run check-types:apps:dist",
    "check-types:apps:dist": "turbo run check-types --filter='./apps/*'",
    "lint": "eslint .",
    "prepare": "husky",
    "docs:dev": "turbo run dev --filter=@lite-fsm/docs",
    "docs:build": "turbo run build --filter=@lite-fsm/docs",
    "docs:start": "pnpm --filter @lite-fsm/docs start",
    "playground:dev": "turbo run dev --filter=@lite-fsm/playground",
    "playground:build": "turbo run build --filter=@lite-fsm/playground",
    "playground:visualizer-ir": "pnpm run build:packages && node scripts/generate-playground-visualizer-ir.mjs",
    "pages:build": "node scripts/build-pages.mjs",
    "pages:build:fast": "node scripts/build-pages.mjs --skip-install",
    "pages:preview": "node scripts/preview-pages.mjs",
    "test": "vitest run",
    "bench": "vitest bench tests/bench",
    "test:types": "tstyche",
    "test:types:dist": "tstyche --config tstyche.dist.json",
    "test:types:all": "pnpm run test:types && pnpm run build:packages && pnpm run test:types:dist",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "visualizer:release": "pnpm --filter @lite-fsm/visualizer build && pnpm --filter @lite-fsm/visualizer test:coverage",
    "publint:release": "pnpm --filter './packages/*' exec publint --strict",
    "smoke:release": "node tests/smoke/esm.mjs && node tests/smoke/cjs.cjs && node tests/smoke/cli.mjs && node tests/smoke/cli-packed.mjs && tsc --noEmit -p tests/smoke/tsconfig.json",
    "test:release": "pnpm run build:packages && pnpm run test:release:dist",
    "test:release:dist": "pnpm run publint:release && pnpm run smoke:release",
    "pack:release": "pnpm --filter './packages/*' pack --dry-run",
    "verify:release": "pnpm run check-types && pnpm run lint && pnpm run test:coverage && pnpm run visualizer:release && pnpm run test:release && pnpm run check-types:apps:dist && pnpm run test:types:dist && pnpm run pack:release",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run verify:release && changeset publish"
  },
  "devDependencies": {
    "@lite-fsm/core": "workspace:*",
    "@lite-fsm/cli": "workspace:*",
    "@lite-fsm/graph": "workspace:*",
    "@lite-fsm/middleware": "workspace:*",
    "@lite-fsm/persist": "workspace:*",
    "@lite-fsm/react": "workspace:*",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "agent-browser": "^0.26.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "immer": "^11.1.4",
    "jsdom": "^29.0.2",
    "next": "^16.2.4",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "react": "^16.8.0 || ^17.0.2 || ^18.2.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.2 || ^18.2.0 || ^19.0.0",
    "shadcn": "^4.6.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "turbo": "^2.6.3",
    "tstyche": "^7.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "use-sync-external-store": "^1.6.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "nextra@4.6.1>zod": "4.3.6",
      "nextra-theme-docs@4.6.1>zod": "4.3.6"
    }
  }
}
